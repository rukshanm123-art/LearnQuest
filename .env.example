# ─────────────────────────────────────────────────────────────
# LearnQuest environment variables
# Copy this file to `.env.local` and fill in the values.
# The app runs fully in DEMO MODE with all of these left blank.
# ─────────────────────────────────────────────────────────────

# Supabase (auth + database). Leave blank to use local demo data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key — NEVER expose to the client. Used by edge/server routes.
SUPABASE_SERVICE_ROLE_KEY=

# AI provider for the tutor + content drafting. Order of preference:
# Gemini → OpenAI → built-in deterministic fallback (works with none set).
# Gemini (Google AI Studio key). gemini-2.5-flash recommended.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# OpenAI (used only if GEMINI_API_KEY is unset).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
NEXT_PUBLIC_APP_NAME=LearnQuest
NEXT_PUBLIC_APP_URL=http://localhost:3000
